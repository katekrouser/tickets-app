{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Hackathon Ticket Tracker — backend (Fastify + Prisma). Serves /api/*, /health, /ready.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "test": "vitest run --config tests/vitest.config.ts",
    "migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@app/shared": "*",
    "@fastify/jwt": "10.1.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^5.0.0",
    "fastify": "^5.0.0",
    "nodemailer": "^9.0.0",
    "prisma": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.0.0",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.0.0",
    "typescript": "5.6.3",
    "vitest": "4.1.10"
  }
}
