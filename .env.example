# Environment Variable Contract (ADR-0007) — EXACTLY these names, no others.
# Copy to `.env` and fill real values. `.env` is gitignored; never commit secrets.
# Values below are safe local-dev defaults for `docker compose up --build`.

# Runtime mode: development | production
NODE_ENV=development

# Postgres DSN. Host `postgres` = compose service name; must match the DB creds.
DATABASE_URL=postgresql://user:pass@postgres:5432/tickets

# Fastify listen port (container-internal; not published to the host).
BACKEND_PORT=3000

# Host port nginx (frontend) is published on. App origin = http://localhost:8080
FRONTEND_PORT=8080

# Base URL used to build email-verification links (must equal the nginx origin).
APP_BASE_URL=http://localhost:8080

# HMAC secret for @fastify/jwt — never commit a real secret.
# Strong random string >=32 chars. Leave unset for an auto-generated ephemeral dev secret; MUST set explicitly in production.
JWT_SECRET=

# Bearer-token lifetime in hours (ADR-0004 default).
JWT_TTL_HOURS=24

# SMTP settings. Dev default targets the optional Mailhog service (profile: dev).
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@localhost
